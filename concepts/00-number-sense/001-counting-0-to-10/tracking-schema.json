{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Local Progress Tracking Schema",
  "type": "object",
  "properties": {
    "conceptId": {
      "type": "string",
      "example": "001-counting-0-to-10"
    },
    "attempts": {
      "type": "integer",
      "description": "Total number of practice or test attempts completed",
      "minimum": 0
    },
    "bestScore": {
      "type": "integer",
      "description": "Highest normalized score achieved (out of 10)",
      "minimum": 0,
      "maximum": 10
    },
    "lastScore": {
      "type": "integer",
      "description": "Score from the most recent run",
      "minimum": 0
    },
    "mastered": {
      "type": "boolean",
      "description": "Flag indicating if the concept is mastered (bestScore >= 8)"
    },
    "lastPracticed": {
      "type": "string",
      "format": "date",
      "description": "ISO date format (YYYY-MM-DD)"
    },
    "mistakePatterns": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["undercounts", "overcounts", "incorrect_choice", "double_counts"]
      }
    }
  }
}
