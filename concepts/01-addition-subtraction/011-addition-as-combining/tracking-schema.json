{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stage 1: Addition as Combining - Student Progress Tracking Schema",
  "type": "object",
  "properties": {
    "conceptId": {
      "type": "string",
      "const": "011-addition-as-combining"
    },
    "attempts": {
      "type": "integer",
      "minimum": 0
    },
    "bestScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "mastered": {
      "type": "boolean"
    },
    "mistakePatterns": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["undercounts", "overcounts", "incorrect_choice"]
      }
    }
  },
  "required": ["conceptId", "attempts", "bestScore", "mastered", "mistakePatterns"]
}
