{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stage 2: Tens and Ones - Student Progress Tracking Schema",
  "type": "object",
  "properties": {
    "conceptId": {
      "type": "string",
      "const": "021-tens-and-ones"
    },
    "attempts": {
      "type": "integer",
      "minimum": 0
    },
    "bestScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "mastered": {
      "type": "boolean"
    },
    "mistakePatterns": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["reversal", "missed_ten", "reversal_like", "added_instead_of_place"]
      }
    }
  },
  "required": ["conceptId", "attempts", "bestScore", "mastered", "mistakePatterns"]
}
